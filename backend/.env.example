# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB: use MongoDB Atlas free tier → https://cloud.mongodb.com
# Or run locally: mongodb://localhost:27017
MONGO_URL=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=lumi

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=your-random-secret-here-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ── AI (Claude via Anthropic) ─────────────────────────────────────────────────
# Sign up at https://console.anthropic.com → API Keys
# The app uses this for face scan + AI stylist features
EMERGENT_LLM_KEY=your-anthropic-api-key-here

# ── Stripe (optional — for checkout) ─────────────────────────────────────────
# Sign up at https://stripe.com → Developers → API Keys
# Leave as test key for development
STRIPE_API_KEY=sk_test_your_stripe_key_here

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:8081
