{
  "expo": {
    "name": "Lumi",
    "slug": "frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "frontend",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan your face for personalized makeup recommendations",
        "NSPhotoLibraryUsageDescription": "Upload a selfie for beauty analysis"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "edgeToEdgeEnabled": true,
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Lumi needs photo access to upload a selfie for beauty analysis.",
          "cameraPermission": "Lumi needs camera access to scan your face for personalized recommendations."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
